{
  "name": "ai-town",
  "version": "0.1.0",
  "description": "Generative Agents - AI生态小镇复刻",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/server/simple-server.ts",
    "start": "tsx src/server/simple-server.ts",
    "stop": "npx kill-port 3061",
    "dev:web": "tsx watch src/server/simple-server.ts",
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "demo": "tsx src/demo.ts",
    "db:setup": "tsx scripts/setup-db.ts",
    "legacy:cli": "tsx src/index.ts",
    "legacy:web": "tsx src/frontend.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "chromadb": "^1.8.0",
    "dotenv": "^16.4.0",
    "openai": "^4.28.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "ai",
    "agents",
    "generative-agents",
    "simulation"
