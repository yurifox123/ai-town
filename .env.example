# LLM配置（四选一）

# ========== 方式1: OpenAI ==========
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ========== 方式2: Claude (Anthropic) ==========
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ========== 方式3: 本地模型 (Ollama) ==========
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama2:7b

# ========== 方式4: 自定义供应商 ==========
# 支持任何兼容 OpenAI API 格式的服务

# --- ModelScope 示例 ---
# LLM_PROVIDER=custom
# CUSTOM_API_KEY=ms-ce92cac0-df49-4703-a667-67dd13674fb6
# CUSTOM_MODEL=qwen/Qwen2-7B-Instruct
# CUSTOM_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
# CUSTOM_RESPONSE_PATH=choices[0].message.content

# --- 通用自定义配置 ---
# LLM_PROVIDER=custom
# CUSTOM_API_KEY=your-api-key
# CUSTOM_MODEL=your-model-name
# CUSTOM_ENDPOINT=https://api.example.com/v1/chat/completions
# CUSTOM_RESPONSE_PATH=choices[0].message.content
# CUSTOM_EMBEDDING_ENDPOINT=https://api.example.com/v1/embeddings
# CUSTOM_EMBEDDING_RESPONSE_PATH=data[0].embedding

# 数据库配置
DATABASE_URL=./data/ai-town.db
CHROMA_DB_PATH=./data/chroma

# 模拟配置
TICK_INTERVAL_MS=5000
MAX_AGENTS=10
WORLD_WIDTH=50
WORLD_HEIGHT=50
TIME_SCALE=60

# 可选：LangSmith调试
# LANGCHAIN_API_KEY=your-key
# LANGCHAIN_PROJECT=ai-town
